@page "/bptest"
@using HomagGroup.Blazor3D.Enums
@using HomagGroup.Blazor3D.Extras.Core
@using HomagGroup.Blazor3D.Geometires
@using HomagGroup.Blazor3D.Lights
@using HomagGroup.Blazor3D.Maths
@using HomagGroup.Blazor3D.Objects
@using HomagGroup.Blazor3D.Scenes
@using HomagGroup.Blazor3D.Settings
@using HomagGroup.Blazor3D.Viewers
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<p>
    Buildplate render test
</p>

<div class="row justify-content-center">
    <div class="col-6 v3d">
        <Viewer @ref="View3D1" ViewerSettings=@settings1 Scene=scene />
    </div>
</div>

@code {
    private Viewer View3D1 = null!;
    private ViewerSettings settings1 = new ViewerSettings()
    {
        ContainerId = "example1",
    };

    private Scene scene = new Scene();

    public void Dispose()
    {
        View3D1.JsModuleLoaded -= OnJsModuleLoaded;
    }

    protected override async Task OnInitializedAsync()
    {
        scene.Add(new AmbientLight());
        scene.Add(new PointLight()
        {
            Position = new Vector3
            {
                X = 1,
                Y = 3,
                Z = 0
            }
        });

        scene.Add(new Mesh
        {
            Geometry = new BoxGeometry
            {
                Width = 2,
                Height = 0.5f
            },
            Position = new Vector3
            {
                X = -1,
                Y = 1,
                Z = -1
            }
                       ,
            Rotation = new Euler
            {
                X = Math.PI / 4
            }
        });
        
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            View3D1.JsModuleLoaded += OnJsModuleLoaded;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task OnJsModuleLoaded()
    {
        var settings = new ImportSettings()
        {
            Format = Import3DFormats.Gltf,
            FileURL = "/CarConcept.glb",
        };

        await View3D1.Import3DModelAsync(settings);
    }
}