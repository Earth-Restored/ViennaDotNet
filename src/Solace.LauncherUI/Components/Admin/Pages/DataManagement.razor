@page "/Admin/Data"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Solace.Common.Utils
@using Solace.LauncherUI.Utils
@using System.IO.Compression
@attribute [Authorize(Policy = Permissions.ViewData)]
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Data - Solace</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-database text-primary"></i> Data Management</h2>

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Space Usage</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 border-end">
                    <h6 class="text-muted">Total Space Used</h6>
                    <h3 class="text-primary">@FormatBytes(_totalSpaceB)</h3>
                </div>
                <div class="col-md-9">
                    <h6 class="text-muted">Storage Split</h6>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-globe"></i> earth.db</span>
                            <span class="badge bg-secondary rounded-pill">@FormatBytes(_earthDbB)</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-activity"></i> live.db</span>
                            <span class="badge bg-secondary rounded-pill">@FormatBytes(_liveDbB)</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-folder"></i> object_store</span>
                            <span class="badge bg-secondary rounded-pill">@FormatBytes(_objectStoreB)</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    @if (HasPermission(Permissions.ExportData))
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">Export Data</h5>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">Backup your current server data.</p>
                <button class="btn btn-outline-primary" @onclick="ExportData">
                    <i class="bi bi-download"></i> Export Data
                </button>
            </div>
        </div>
    }

    @if (HasPermission(Permissions.EditData))
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">Edit Data</h5>
            </div>
            <div class="card-body">
                <section class="mb-5">
                    <h6><i class="bi bi-file-earmark-zip"></i> Import Data</h6>
                    <p class="small text-muted">
                        Merge an existing dataset. Supported structures (zip these files/folders): <br />
                        <strong>Solace:</strong> <code>earth.db</code>, <code>live.db</code>, <code>object_store/</code> |
                        <strong>Vienna:</strong> <code>db/</code>, <code>objects/</code>
                    </p>

                    <div class="input-group">
                        <InputFile OnChange="HandleFileSelected" class="form-control" accept=".zip" />
                        @if (_selectedFile != null)
                        {
                            <button class="btn btn-primary" @onclick="InitiateImport">
                                <i class="bi bi-cloud-upload"></i> Upload & Process
                            </button>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(_uploadError))
                    {
                        <div class="text-danger small mt-2">@_uploadError</div>
                    }
                </section>

                <hr />

                <section class="mt-4">
                    <h6 class="text-danger"><i class="bi bi-exclamation-triangle"></i> Danger Zone</h6>
                    <p class="small text-muted">
                        Deleting all server data is a permanent action and cannot be undone. This will wipe the databases
                        and the object store.
                    </p>

                    @if (!_isConfirmingDelete)
                    {
                        <button class="btn btn-outline-danger btn-sm" @onclick="InitiateDelete">
                            Delete All Data
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-warning d-flex align-items-center" role="alert">
                            <div class="me-auto">
                                <strong>Are you absolutely sure?</strong>
                                @if (!_canConfirmDelete)
                                {
                                    <span class="ms-1 text-dark"> Please wait @_countdown seconds...</span>
                                }
                            </div>
                            <div>
                                <button class="btn btn-sm btn-secondary me-2" @onclick="CancelDelete">Cancel</button>
                                <button class="btn btn-sm btn-danger" disabled="@(!_canConfirmDelete)" @onclick="ExecuteDelete">
                                    Yes, Delete Everything
                                </button>
                            </div>
                        </div>
                    }
                </section>
            </div>
        </div>
    }
</div>

@if (_showImportWarning)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle"></i> Merge Warning</h5>
                    <button type="button" class="btn-close" @onclick="CancelImport"></button>
                </div>
                <div class="modal-body">
                    <p>Data already exists on this server. Importing a new dataset will <strong>merge</strong> the incoming
                        data with the existing records.</p>
                        <p class="mb-0 text-muted small">Conflicts will be resolved by keeping the newest records. Do you wish
                            to proceed?</p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CancelImport">Cancel</button>
                            <button type="button" class="btn btn-warning" @onclick="ConfirmImport">Proceed with Merge</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (_isProcessing)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.7); z-index: 1060;">
                <div class="modal-dialog modal-dialog-centered modal-sm">
                    <div class="modal-content bg-transparent border-0 text-center">
                        <div class="modal-body text-white">
                            <div class="spinner-border text-light mb-3" role="status" style="width: 3rem; height: 3rem;">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <h5>@_processingAction...</h5>
                            <p class="small text-light opacity-75">Please do not close this page.</p>
                        </div>
                    </div>
                </div>
            </div>
        }

@code {
    private ClaimsPrincipal? _user;

    private FileInfo _earthDB = null!;
    private FileInfo _liveDB = null!;
    private DirectoryInfo _objectStore = null!;

    // View states - Delete
    private bool _isConfirmingDelete = false;
    private bool _canConfirmDelete = false;
    private int _countdown = 5;

    // View states - Import/Export
    private bool _showImportWarning = false;
    private bool _isProcessing = false;
    private string _processingAction = "";

    // import
    private IBrowserFile? _selectedFile;
    private string? _uploadError;
    private long _maxAllowedSize = 1024 * 1024 * 500;

    // Size
    private long _totalSpaceB => long.Max(_earthDbB + _liveDbB + _objectStoreB, -1);
    private long _earthDbB = -1;
    private long _liveDbB = -1;
    private long _objectStoreB = -1;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;

        _earthDB = new FileInfo(Settings.Instance.EarthDatabaseConnectionString!);
        _liveDB = new FileInfo(Settings.Instance.LiveDatabaseConnectionString!);
        _objectStore = new DirectoryInfo(Path.Combine(Program.DataDirRelative, Program.ObjectStoreDirName));

        LoadSizes();
    }

    private void LoadSizes()
    {
        _earthDbB = _earthDB.SafeLength;
        _liveDbB = _liveDB.SafeLength;
        _objectStoreB = _objectStore.SafeLength;
    }

    private bool HasPermission(string permission)
        => _user?.HasPermission(permission) ?? false;

    private async Task ExportData()
    {
        _processingAction = "Exporting Data";
        _isProcessing = true;
        
        try
        {
            NavigationManager.NavigateTo("api/data/export", forceLoad: true);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void InitiateImport()
    {
        if (_selectedFile is null)
        {
            return;
        }

        if (_totalSpaceB > 0)
        {
            _showImportWarning = true;
        }
        else
        {
            ConfirmImport()
                .Forget();
        }
    }

    private void CancelImport()
    {
        _showImportWarning = false;
    }

    private async Task ConfirmImport()
    {
        if (_selectedFile is null)
        {
            return;
        }

        _showImportWarning = false;
        _isProcessing = true;
        _processingAction = "Uploading";

        try
        {
            await ProcessZipFileAsync(_selectedFile);
            _selectedFile = null;
        }
        finally
        {
            _isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task InitiateDelete()
    {
        _isConfirmingDelete = true;
        _canConfirmDelete = false;
        _countdown = 5;

        while (_countdown > 0 && _isConfirmingDelete)
        {
            await Task.Delay(1000);
            _countdown--;
            StateHasChanged();
        }

        if (_isConfirmingDelete)
        {
            _canConfirmDelete = true;
            StateHasChanged();
        }
    }

    private void CancelDelete()
    {
        _isConfirmingDelete = false;
        _canConfirmDelete = false;
    }

    private async Task ExecuteDelete()
    {
        _earthDbB = 0;
        _liveDbB = 0;
        _objectStoreB = 0;
        
        _isConfirmingDelete = false;
        _canConfirmDelete = false;
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _uploadError = null;
        _selectedFile = e.File;

        if (!_selectedFile.Name.EndsWith(".zip", StringComparison.OrdinalIgnoreCase))
        {
            _uploadError = "Please select a valid .zip file.";
            _selectedFile = null;
        }
    }

    private async Task ProcessZipFileAsync(IBrowserFile file)
    {
        try
        {
            using var stream = file.OpenReadStream(_maxAllowedSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Seek(0, SeekOrigin.Begin);

            using var archive = new ZipArchive(ms, ZipArchiveMode.Read);
            
            bool isSolace = false;
            bool isVienna = false;

            // Detect Structure
            if (archive.Entries.Any(e => e.FullName.Equals("earth.db", StringComparison.OrdinalIgnoreCase)))
                isSolace = true;
            else if (archive.Entries.Any(e => e.FullName.StartsWith("db/earth.db", StringComparison.OrdinalIgnoreCase)))
                isVienna = true;

            if (!isSolace && !isVienna)
            {
                _uploadError = "Invalid ZIP structure. Please follow Solace or Vienna format.";
                return;
            }

            _processingAction = isSolace ? "Processing Solace Format" : "Processing Vienna Format";
            StateHasChanged();

            // Logic to move files to your storage location
            foreach (var entry in archive.Entries)
            {
                // Example: Extracting GUID files from object stores
                if (entry.FullName.Contains("object_store/") || entry.FullName.Contains("objects/"))
                {
                    // Logic to write entry.Open() to your destination path
                }
            }

            LoadSizes();
        }
        catch (Exception ex)
        {
            _uploadError = $"Error processing file: {ex.Message}";
        }
    }

    private static readonly string[] SizeUnits = ["B", "KB", "MB", "GB", "TB", "PB"];

    private string FormatBytes(long bytes)
    {
        if (bytes is -1)
        {
            return "? B";
        }

        if (bytes is <= 0)
        {
            return "0 B";
        }

        int unitIndex = 0;
        double displaySize = bytes;

        while (displaySize >= 1024 && unitIndex < SizeUnits.Length - 1)
        {
            displaySize /= 1024;
            unitIndex++;
        }

        return $"{displaySize:n2} {SizeUnits[unitIndex]}";
    }
}