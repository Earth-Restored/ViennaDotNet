@page "/Admin/Data"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Microsoft.Data.Sqlite
@using Serilog
@using Solace.Common.Utils
@using Solace.DB
@using Solace.LauncherUI.Utils
@using System.IO.Compression
@using System.Diagnostics
@using System.Numerics
@attribute [Authorize(Policy = Permissions.ViewData)]
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ServerManager ServerManager
@inject IJSRuntime JS

<PageTitle>Data - Solace</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-database text-primary"></i> Data Management</h2>

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Space Usage</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 border-end">
                    <h6 class="text-muted">Total Space Used</h6>
                    <h3 class="text-primary">@FormatBytes(_totalSpaceB)</h3>
                </div>
                <div class="col-md-9">
                    <h6 class="text-muted">Storage Split</h6>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-globe"></i> earth.db</span>
                            <span class="badge bg-secondary rounded-pill">@FormatBytes(_earthDbB)</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-activity"></i> live.db</span>
                            <span class="badge bg-secondary rounded-pill">@FormatBytes(_liveDbB)</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-folder"></i> object_store</span>
                            <span class="badge bg-secondary rounded-pill">@FormatBytes(_objectStoreB)</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    @if (HasPermission(Permissions.ExportData))
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">Export Data</h5>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">Backup your current server data.</p>
                <button class="btn btn-outline-primary" @onclick="ExportData">
                    <i class="bi bi-download"></i> Export Data
                </button>
            </div>
        </div>
    }

    @if (HasPermission(Permissions.EditData))
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">Edit Data</h5>
            </div>
            <div class="card-body">
                <section class="mb-5">
                    <h6><i class="bi bi-file-earmark-zip"></i> Import Data</h6>
                    <p class="small text-muted">
                        Merge an existing dataset. Supported structures (zip these files/folders): <br />
                        <strong>Solace:</strong> <code>earth.db</code>, <code>live.db</code>, <code>object_store/</code> |
                        <strong>Vienna:</strong> <code>db/</code>, <code>objects/</code>
                    </p>

                    <div class="input-group">
                        <InputFile @key="_inputFileId" OnChange="HandleFileSelected" class="form-control" accept=".zip" />
                        @if (_selectedFile != null)
                        {
                            <button class="btn btn-primary" @onclick="InitiateImport">
                                <i class="bi bi-cloud-upload"></i> Upload & Process
                            </button>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(_uploadError))
                    {
                        <div class="text-danger small mt-2">@_uploadError</div>
                    }
                </section>

                <hr />

                <section class="mt-4">
                    <h6 class="text-danger"><i class="bi bi-exclamation-triangle"></i> Danger Zone</h6>
                    <p class="small text-muted">
                        Deleting all server data is a permanent action and cannot be undone. This will wipe the databases
                        and the object store.
                    </p>

                    @if (!_isConfirmingDelete)
                    {
                        <button class="btn btn-outline-danger btn-sm" @onclick="InitiateDelete">
                            Delete All Data
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-warning d-flex align-items-center" role="alert">
                            <div class="me-auto">
                                <strong>Are you absolutely sure?</strong>
                                @if (!_canConfirmDelete)
                                {
                                    <span class="ms-1 text-dark"> Please wait @_countdown seconds...</span>
                                }
                            </div>
                            <div>
                                <button class="btn btn-sm btn-secondary me-2" @onclick="CancelDelete">Cancel</button>
                                <button class="btn btn-sm btn-danger" disabled="@(!_canConfirmDelete)" @onclick="ExecuteDelete">
                                    Yes, Delete Everything
                                </button>
                            </div>
                        </div>
                    }
                </section>
            </div>
        </div>
    }
</div>

@if (_showImportWarning)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle"></i> Merge Warning</h5>
                    <button type="button" class="btn-close" @onclick="CancelImport"></button>
                </div>
                <div class="modal-body">
                    <p>
                        Data already exists on this server. Importing a new dataset will <strong>merge</strong> the incoming
                        data with the existing records.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelImport">Cancel</button>
                    <button type="button" class="btn btn-warning" @onclick="ConfirmImport">Proceed with Merge</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_isProcessing)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.7); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content bg-transparent border-0 text-center">
                <div class="modal-body text-white">
                    <div class="spinner-border text-light mb-3" role="status" style="width: 3rem; height: 3rem;">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <h5>@_processingAction...</h5>
                    <p class="small text-light opacity-75">Please do not close this page.</p>
                </div>
            </div>
        </div>
    </div>
}

@if (_mergeConflictTcs != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.8); z-index: 1070;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-arrows-collapse"></i> Merge Conflict</h5>
                </div>
                <div class="modal-body">
                    <p>A collision was detected for: <strong>@_conflictContext</strong></p>
                    
                    <div class="row mb-3 text-center">
                        <div class="col-6 border-end">
                            <h6 class="text-muted small text-uppercase">Current Server</h6>
                            <span class="fs-5">@_currentValueDisplay</span>
                        </div>
                        <div class="col-6">
                            <h6 class="text-muted small text-uppercase">Incoming Data</h6>
                            <span class="fs-5">@_incomingValueDisplay</span>
                        </div>
                    </div>

                    <div class="bg-light p-3 rounded border">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="alwaysApplyCheck" @bind="_alwaysApplyChoice" />
                            <label class="form-check-label user-select-none" for="alwaysApplyCheck">
                                Always apply my choice to future conflicts
                            </label>
                        </div>

                        @if (_alwaysApplyChoice && _supportsAutomatic)
                        {
                            <div class="mt-3 p-2 border-start border-3 border-warning">
                                <label class="small text-muted mb-1">
                                    If you choose 'Automatic', but 'Automatic' is unavailable in a
                                    future conflict, fallback to:
                                </label>
                                <select class="form-select form-select-sm" @bind="_fallbackAction">
                                    <option value="@MergeAction.KeepCurrent">Keep Current</option>
                                    <option value="@MergeAction.KeepIncoming">Keep Incoming</option>
                                </select>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer d-flex">
                    <div class="flex-fill text-start">
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => ResolveConflict(MergeAction.KeepCurrent)">
                            Keep Current
                        </button>
                    </div>

                    <div class="flex-fill text-center">
                        @if (_supportsAutomatic)
                        {
                            <button type="button" class="btn btn-success" @onclick="() => ResolveConflict(MergeAction.Auto)">
                                Automatic
                            </button>
                        }
                        else
                        {
                            <span>&nbsp;</span>
                        }
                    </div>

                    <div class="flex-fill text-end">
                        <button type="button" class="btn btn-outline-primary" @onclick="() => ResolveConflict(MergeAction.KeepIncoming)">
                            Keep Incoming
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private ClaimsPrincipal? _user;

    private FileInfo _earthDB = null!;
    private FileInfo _liveDB = null!;
    private DirectoryInfo _objectStore = null!;

    // View states - Delete
    private bool _isConfirmingDelete = false;
    private bool _canConfirmDelete = false;
    private int _countdown = 5;

    // View states - Import/Export
    private bool _showImportWarning = false;
    private bool _isProcessing = false;
    private string _processingAction = "";

    private Guid _inputFileId = Guid.NewGuid();

    // import
    private IBrowserFile? _selectedFile;
    private string? _uploadError;
    private long _maxAllowedSize = 1024 * 1024 * 500;

    // merge conflict
    private TaskCompletionSource<MergeAction>? _mergeConflictTcs;

    private string _conflictContext = "";
    private string _currentValueDisplay = "";
    private string _incomingValueDisplay = "";
    private bool _supportsAutomatic = false;
    private bool _alwaysApplyChoice = false;
    private MergeAction _fallbackAction = MergeAction.KeepIncoming;

    private MergeAction? _globalMergePreference = null;
    private MergeAction? _globalFallbackPreference = null;

    // Size
    private long _totalSpaceB => long.Max(_earthDbB + _liveDbB + _objectStoreB, -1);
    private long _earthDbB = -1;
    private long _liveDbB = -1;
    private long _objectStoreB = -1;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;

        _earthDB = new FileInfo(Settings.Instance.EarthDatabaseConnectionString!);
        _liveDB = new FileInfo(Settings.Instance.LiveDatabaseConnectionString!);
        _objectStore = new DirectoryInfo(Path.Combine(Program.DataDirRelative, Program.ObjectStoreDirName));

        LoadSizes();
    }

    private void LoadSizes()
    {
        _earthDB.Refresh();
        _liveDB.Refresh();
        _objectStore.Refresh();

        _earthDbB = _earthDB.SafeLength;
        _liveDbB = _liveDB.SafeLength;
        _objectStoreB = _objectStore.SafeLength;
    }

    private bool HasPermission(string permission)
        => _user?.HasPermission(permission) ?? false;

    private async Task ExportData()
    {
        _processingAction = "Exporting Data";
        _isProcessing = true;

        try
        {
            NavigationManager.NavigateTo("api/data/export", forceLoad: true);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task InitiateImport()
    {
        if (ServerManager.AnyOnline)
        {
            await JS.InvokeVoidAsync("alert", "The server needs to be offline to import data.");
            return;
        }

        if (_selectedFile is null)
        {
            return;
        }

        if (_totalSpaceB > 0)
        {
            _showImportWarning = true;
        }
        else
        {
            ConfirmImport()
                .Forget();
        }
    }

    private void CancelImport()
    {
        _showImportWarning = false;
    }

    private async Task ConfirmImport()
    {
        if (_selectedFile is null)
        {
            return;
        }

        _showImportWarning = false;
        _isProcessing = true;
        _fallbackAction = MergeAction.KeepIncoming;
        _globalMergePreference = null;
        _globalFallbackPreference = null;
        _processingAction = "Uploading";

        try
        {
            await ProcessZipFileAsync(_selectedFile);
            _selectedFile = null;
            _inputFileId = Guid.NewGuid();
        }
        finally
        {
            _isProcessing = false;
            LoadSizes();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task InitiateDelete()
    {
        if (ServerManager.AnyOnline)
        {
            await JS.InvokeVoidAsync("alert", "The server needs to be offline to delete data.");
            return;
        }

        _isConfirmingDelete = true;
        _canConfirmDelete = false;
        _countdown = 5;

        while (_countdown > 0 && _isConfirmingDelete)
        {
            await Task.Delay(1000);
            _countdown--;
            StateHasChanged();
        }

        if (_isConfirmingDelete)
        {
            _canConfirmDelete = true;
            StateHasChanged();
        }
    }

    private void CancelDelete()
    {
        _isConfirmingDelete = false;
        _canConfirmDelete = false;
    }

    private async Task ExecuteDelete()
    {
        _earthDB.SafeDelete();
        _liveDB.SafeDelete();
        _objectStore.SafeDelete(recursive: true);

        LoadSizes();

        _isConfirmingDelete = false;
        _canConfirmDelete = false;

        StateHasChanged();
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _uploadError = null;
        _selectedFile = e.File;

        if (!_selectedFile.Name.EndsWith(".zip", StringComparison.OrdinalIgnoreCase))
        {
            _uploadError = "Please select a valid .zip file.";
            _selectedFile = null;
        }
    }

    private async Task ProcessZipFileAsync(IBrowserFile file)
    {
        try
        {
            using var stream = file.OpenReadStream(_maxAllowedSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Seek(0, SeekOrigin.Begin);

            using var archive = new ZipArchive(ms, ZipArchiveMode.Read);

            bool isSolace = false;
            bool isVienna = false;

            // Detect Structure
            if (archive.Entries.Any(e => e.FullName.Equals("earth.db", StringComparison.OrdinalIgnoreCase)))
            {
                isSolace = true;
            }
            else if (archive.Entries.Any(e => e.FullName.StartsWith("db/earth.db", StringComparison.OrdinalIgnoreCase)))
            {
                isVienna = true;
            }

            if (!isSolace && !isVienna)
            {
                _uploadError = "Invalid ZIP structure. Please follow Solace or Vienna format.";
                return;
            }

            _processingAction = isSolace ? "Processing Solace Format" : "Processing Vienna Format";
            StateHasChanged();

            string earthDbFile = isSolace ? "earth.db" : "db/earth.db";
            string? liveDbFile = isSolace ? "live.db" : null;
            string objectsDir = isSolace ? "object_store" : "objects";

            var earthDbEntry = archive.GetEntry(earthDbFile);
            if (earthDbEntry is not null)
            {
                await ImportEarthDb(earthDbEntry, isSolace);
            }

            var liveDbEntry = liveDbFile is null ? null : archive.GetEntry(liveDbFile);
            if (liveDbEntry is not null)
            {
                // todo: merge
                await liveDbEntry.ExtractToFileAsync(_liveDB.FullName, overwrite: true);
            }

            foreach (var entry in archive.Entries)
            {
                if (!entry.IsDirectory && entry.FullName.StartsWith(objectsDir))
                {
                    string destinationFileName = Path.Combine(_objectStore.FullName, Path.GetRelativePath(objectsDir, entry.FullName));
                    Directory.CreateDirectory(Path.GetDirectoryName(destinationFileName)!);
                    await entry.ExtractToFileAsync(destinationFileName, overwrite: true);
                }
            }
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Error processing file");
            _uploadError = $"Error processing file: {ex.Message}";
        }
    }

    private async Task ImportEarthDb(ZipArchiveEntry earthDbEntry, bool isSolace)
    {
        if (isSolace && !_earthDB.Exists)
        {
            await earthDbEntry.ExtractToFileAsync(_earthDB.FullName, overwrite: false);
        }

        using var currentDb = EarthDB.Open(Settings.Instance.EarthDatabaseConnectionString!);
        using var liveDb = DataUtils.OpenLiveDB(Settings.Instance);

        var importDbPath = Path.GetTempFileName();
        await earthDbEntry.ExtractToFileAsync(importDbPath, overwrite: true);
        using var importDb = new SqliteConnection("Data Source=" + importDbPath);
        await importDb.OpenAsync();

        try
        {
            // todo: sharedBuildplates SharedBuildplates id: "", encounterBuildplates EncounterBuildplates id: ""
            // reset preference after each one?
            await ImportTypeSame<Solace.DB.Models.Player.Profile>("profile", async (userId, current, import, query) =>
            {
                current.Health = await AutoMergeNumber(current.Health, import.Health, nameof(current.Health), userId);
                current.Experience = await AutoMergeNumber(current.Experience, import.Experience, nameof(current.Experience), userId);
                current.Level = await AutoMergeNumber(current.Level, import.Level, nameof(current.Level), userId);
                current.Rubies.Purchased = await AutoMergeNumber(current.Rubies.Purchased, import.Rubies.Purchased, "Purchased rubies", userId);
                current.Rubies.Earned = await AutoMergeNumber(current.Rubies.Earned, import.Rubies.Earned, "Earned rubies", userId);

                query.Update("profile", userId, current);
            });

            await ImportTypeSame<Solace.DB.Models.Player.Journal>("journal", async (userId, current, import, query) =>
            {
                foreach (var item in import.Items)
                {
                    if (!current.Items.TryGetValue(item.Key, out var currentValue))
                    {
                        current.Items.Add(item.Key, item.Value);
                    }
                    else
                    {
                        currentValue = currentValue with
                        {
                            FirstSeen = await AutoMerge(currentValue.FirstSeen, item.Value.FirstSeen, $"Journal item first seen '{item.Key}'", userId, long.Min),
                            LastSeen = await AutoMergeNumber(currentValue.LastSeen, item.Value.LastSeen, $"Journal item last seen '{item.Key}'", userId),
                            AmountCollected = await AutoMergeNumber(currentValue.AmountCollected, item.Value.AmountCollected, $"Journal item amount collected '{item.Key}'", userId),
                        };
                        current.Items[item.Key] = currentValue;
                    }
                }
                
                query.Update("journal", userId, current);
            });

            await ImportTypeSame<Solace.DB.Models.Player.Hotbar>("hotbar", async (userId, current, import, query) =>
            {
                for (var i = 0; i < current.Items.Length; i++)
                {
                    current.Items[i] = await AutoMerge(current.Items[i], import.Items[i], $"Hotbar slot {i + 1}", userId, null);
                }

                query.Update("hotbar", userId, current);
            });

            await ImportTypeSame<Solace.DB.Models.Player.Inventory>("inventory", async (userId, current, import, query) =>
            {
                foreach (var item in import.StackableItems)
                {
                    if (!current._stackableItems.TryGetValue(item.Id, out var currentValue))
                    {
                        current._stackableItems.Add(item.Id, item.Count);
                    }
                    else
                    {
                        // todo: resolve name
                        current._stackableItems[item.Id] = await AutoMergeNumber(currentValue ?? 0, item.Count ?? 0, $"Inventory item '{item.Id}'", userId);
                    }
                }

                foreach (var item in import._nonStackableItems)
                {
                    if (!current._nonStackableItems.TryGetValue(item.Key, out var currentValue))
                    {
                        current._nonStackableItems.Add(item.Key, item.Value);
                    }
                    else
                    {
                        foreach (var item2 in item.Value)
                        {
                            currentValue[item2.Key] = item2.Value;
                        }
                    }
                }

                query.Update("inventory", userId, current);
            });
        
            await ImportTypeSame<Solace.DB.Models.Player.Tokens>("tokens", async (userId, current, import, query) =>
            {
                foreach (var item in import._tokens)
                {
                    current._tokens[item.Key] = item.Value;
                }

                query.Update("tokens", userId, current);
            });

            await ImportTypeSame<Solace.DB.Models.Player.Workshop.CraftingSlots>("crafting", async (userId, current, import, query) =>
            {
                for (var i = 0; i < import.Slots.Length; i++)
                {
                    var importSlot = import.Slots[i];
                    var slot = current.Slots[i];

                    slot.Locked = await AutoMerge(slot.Locked, importSlot.Locked, $"Crafting slot {i + 1} unlocked", userId, null);

                    if (slot.ActiveJob is null)
                    {
                        slot.ActiveJob = importSlot.ActiveJob;
                    }
                    else if (importSlot.ActiveJob is not null)
                    {
                        slot.ActiveJob = (await AutoMerge(slot.ActiveJob.RecipeId, importSlot.ActiveJob.RecipeId, $"Crafting slot {i + 1} recipe", userId, null)) == slot.ActiveJob.RecipeId ? slot.ActiveJob : importSlot.ActiveJob;
                    }
                }

                query.Update("crafting", userId, current);
            });

            await ImportTypeSame<Solace.DB.Models.Player.Workshop.SmeltingSlots>("smelting", async (userId, current, import, query) =>
            {
                for (var i = 0; i < import.Slots.Length; i++)
                {
                    var importSlot = import.Slots[i];
                    var slot = current.Slots[i];

                    slot.Locked = await AutoMerge(slot.Locked, importSlot.Locked, $"Smelting slot {i + 1} unlocked", userId, null);

                    if (slot.ActiveJob is null)
                    {
                        slot.ActiveJob = importSlot.ActiveJob;
                    }
                    else if (importSlot.ActiveJob is not null)
                    {
                        slot.ActiveJob = (await AutoMerge(slot.ActiveJob.RecipeId, importSlot.ActiveJob.RecipeId, $"Smelting slot {i + 1} recipe", userId, null)) == slot.ActiveJob.RecipeId ? slot.ActiveJob : importSlot.ActiveJob;
                    }
                }

                query.Update("smelting", userId, current);
            });

            await ImportTypeSame<Solace.DB.Models.Player.RedeemedTappables>("redeemedTappables", async (userId, current, import, query) =>
            {
                foreach (var item in import._tappables)
                {
                    if (!current._tappables.TryGetValue(item.Key, out var currentValue))
                    {
                        current._tappables.Add(item.Key, item.Value);
                    }
                    else
                    {
                        current._tappables[item.Key] = long.Max(currentValue, item.Value);
                    }
                }

                query.Update("redeemedTappables", userId, current);
            });

            await ImportTypeSame<Solace.DB.Models.Player.Boosts>("boosts", async (userId, current, import, query) =>
            {
                for (var i = 0; i < import.ActiveBoosts.Length; i++)
                {
                    if (current.ActiveBoosts[i] is null)
                    {
                        current.ActiveBoosts[i] = import.ActiveBoosts[i];
                    }
                    else if (import.ActiveBoosts[i] is not null)
                    {
                        current.ActiveBoosts[i] = await AutoMerge(current.ActiveBoosts[i]!, import.ActiveBoosts[i]!, $"Boost slot {i + 1}", userId, null);
                    }
                }

                query.Update("boosts", userId, current);
            });

            await ImportTypeSame<Solace.DB.Models.Player.ActivityLog>("activityLog", async (userId, current, import, query) =>
            {
                current = await AutoMerge(current, import, "Activity log", userId, null);

                query.Update("activityLog", userId, current);
            });

            await ImportType<Solace.DB.Models.Player.Buildplates, Solace.DB.Models.Player.Buildplates.Vienna>("buildplates",
            buildplates =>
            {
                var result = new DB.Models.Player.Buildplates();

                result._buildplates.EnsureCapacity(buildplates._buildplates.Count);

                foreach (var item in buildplates._buildplates)
                {
                    result._buildplates.Add(item.Key, new(null, "Imported buildplate", item.Value.Size, item.Value.Offset, item.Value.Scale, item.Value.Night, item.Value.LastModified, item.Value.ServerDataObjectId, item.Value.PreviewObjectId));
                }

                return result;
            },
            async (userId, current, import, query) =>
            {
                foreach (var item in import._buildplates)
                {
                    current._buildplates[item.Key] = item.Value;
                }

                query.Update("buildplates", userId, current);
            });
        }
        finally
        {
            File.Delete(importDbPath);
        }

        async Task<TValue> AutoMergeNumber<TValue>(TValue currentValue, TValue importValue, string propertyName, string userId)
            where TValue : INumber<TValue>
            => await AutoMerge<TValue>(currentValue, importValue, propertyName, userId, TValue.Max);

        async Task<TValue> AutoMerge<TValue>(TValue currentValue, TValue importValue, string propertyName, string userId, Func<TValue, TValue, TValue>? getAuto)
            where TValue : IEquatable<TValue>
        {
            if (currentValue?.Equals(importValue) ?? importValue is null)
            {
                return currentValue!;
            }

            var name = liveDb is null ? null : await DataUtils.GetUsername(userId, liveDb);

            var mergeAction = await PromptMergeConflictAsync($"{propertyName} is different in imported data (user id: {userId}{(name is null ? "" : $", username: {name}")})", currentValue?.ToString() ?? "null", importValue?.ToString() ?? "null", getAuto is not null);

            return mergeAction switch
            {
                MergeAction.KeepCurrent => currentValue!,
                MergeAction.KeepIncoming => importValue!,
                MergeAction.Auto => getAuto!(currentValue!, importValue!),
                _ => currentValue!,
            };
        }

        async Task ImportTypeSame<T>(string name, Action<string, T, T,
EarthDB.Query> merge)
            where T : class, IEquatable<T>
            => await ImportType<T, T>(name, value => value, merge);

        async Task ImportType<TSolace, TVienna>(string name, Func<TVienna, TSolace> viennaToSolace, Action<string, TSolace, TSolace,
EarthDB.Query> merge)
            where TSolace : class, IEquatable<TSolace>
            where TVienna : class
        {
            foreach (var (id, valueString) in EnumerateObjectsByType(importDb, name))
            {
                TSolace importValue;
                if (isSolace)
                {
                    var solaceValue = EarthDB.FromJson<TSolace>(valueString);
                    if (solaceValue is null)
                    {
                        continue;
                    }

                    importValue = solaceValue;
                }
                else
                {
                    var viennaValue = EarthDB.FromJson<TVienna>(valueString);
                    if (viennaValue is null)
                    {
                        continue;
                    }

                    importValue = viennaToSolace(viennaValue);
                }
                
                await new EarthDB.Query(true)
                    .Get(name, id, typeof(TSolace))
                    .Then(results =>
                    {
                        var query = new EarthDB.Query(true);

                        var currentValue = results.GetExisting<TSolace>(name);

                        if (currentValue is null || currentValue.Equals(importValue))
                        {
                            query.Update(name, id, importValue);
                        }
                        else
                        {
                            merge(id, currentValue, importValue, query);
                        }

                        return query;
                    })
                    .ExecuteAsync(currentDb);
            }
        }

        static IEnumerable<(string Id, string Value)> EnumerateObjectsByType(SqliteConnection connection, string
objectType)
        {
            const string query = $"SELECT id, value FROM {EarthDB.ObjectsTable} WHERE type = @type";

            using (var command = new SqliteCommand(query, connection))
            {
                command.Parameters.AddWithValue("@type", objectType);

                using (var reader = command.ExecuteReader())
                {
                    while (reader.Read())
                    {
                        yield return (
                            Id: reader.GetString(0),
                            Value: reader.GetString(1)
                        );
                    }
                }
            }
        }
    }

    private static readonly string[] SizeUnits = ["B", "KB", "MB", "GB", "TB", "PB"];

    private string FormatBytes(long bytes)
    {
        if (bytes is -1)
        {
            return "? B";
        }

        if (bytes is <= 0)
        {
            return "0 B";
        }

        int unitIndex = 0;
        double displaySize = bytes;

        while (displaySize >= 1024 && unitIndex < SizeUnits.Length - 1)
        {
            displaySize /= 1024;
            unitIndex++;
        }

        return $"{displaySize:n2} {SizeUnits[unitIndex]}";
    }

    private async Task<MergeAction> PromptMergeConflictAsync(string context, string currentValue, string incomingValue, bool
allowAutomatic)
    {
        _globalMergePreference = MergeAction.Auto;
        if (_globalMergePreference.HasValue)
        {
            if (_globalMergePreference.Value == MergeAction.Auto && !allowAutomatic)
            {
                if (_globalFallbackPreference.HasValue)
                {
                    return _globalFallbackPreference.Value;
                }
            }
            else
            {
                return _globalMergePreference.Value;
            }
        }

        _conflictContext = context;
        _currentValueDisplay = currentValue;
        _incomingValueDisplay = incomingValue;
        _supportsAutomatic = allowAutomatic;
        _alwaysApplyChoice = false;
        _fallbackAction = MergeAction.KeepIncoming;

        _mergeConflictTcs = new TaskCompletionSource<MergeAction>();
        StateHasChanged();

        var finalAction = await _mergeConflictTcs.Task;

        if (_alwaysApplyChoice)
        {
            _globalMergePreference = finalAction;
            if (finalAction == MergeAction.Auto)
            {
                _globalFallbackPreference = _fallbackAction;
            }
        }

        _mergeConflictTcs = null;
        StateHasChanged();

        return finalAction;
    }

    private void ResolveConflict(MergeAction actionSelected)
    {
        _mergeConflictTcs?.SetResult(actionSelected);
    }

    public enum MergeAction
    {
        KeepCurrent,
        KeepIncoming,
        Auto
    }
}